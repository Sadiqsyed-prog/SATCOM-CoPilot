    "description": "ISS pass over Bengaluru with clear sky — full pipeline",
    "query": "When does the ISS pass over Bengaluru in the next 3 days?",
    "expected_intent": "TRACK_PASS",
    "expected_satellite": "ISS (ZARYA)",
    "expected_norad_id": 25544,
